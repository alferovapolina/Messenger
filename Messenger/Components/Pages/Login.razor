@page "/login"
@attribute [StreamRendering]

@rendermode InteractiveServer

@using Messenger.DataModels
@inject ApplicationContextFactory dbFactory

@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage session

@inject NavigationManager navigation
<PageTitle>Логин </PageTitle>


@if (initialized && userId == null)
{
	<h1>Введите имя пользователя</h1>
	<p>
		<input id="username" name="username" type=" text" @bind-value="@username" />
	</p>
	<button @onclick="RegisterButton_Click">
		Логин/Регистрация
	</button>
}
@code
{
	int? userId = null;

	bool initialized = false;
	string username = "";

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			var result = await session.GetAsync<int>("userId");
			if (result.Success)
			{
				userId = result.Value;
			}
			initialized = true;
			StateHasChanged();
		}

		if (userId != null)
		{
			navigation.NavigateTo($"/");
		}

		if (!initialized)
		{
			using ApplicationContext db = dbFactory.CreateDbContext();

			StateHasChanged();
		}


	}

	private async Task RegisterButton_Click(MouseEventArgs args)
	{
		using ApplicationContext db = dbFactory.CreateDbContext();

		var user = db.Users.Where(u => u.Name.ToLower() == username.ToLower()).SingleOrDefault();
		if(user!= null)
		{
			userId = user.Id;
		}
		else
		{
			user = new User()
				{
					Name = username
				};
			db.Users.Add(user);
			db.SaveChanges();
			userId = user.Id;
		}

		await session.SetAsync("userId",userId.Value);

		navigation.NavigateTo( $"/");
	}

}