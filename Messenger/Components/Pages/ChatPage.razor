@page "/chat/{chatId:int}"
@attribute [StreamRendering]

@rendermode InteractiveServer

@using Messenger.DataModels
@using Microsoft.EntityFrameworkCore
@inject ApplicationContextFactory dbFactory
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage session
@inject NavigationManager navigation
@implements IDisposable

<h3>Chat ID = @chatId</h3>

@if (userId != null)
{
    <div>
        <h4>Сообщения:</h4>
        <div style="max-height: 400px; overflow-y: auto;">
            @if (messages != null && messages.Any())
            {
                @foreach (var message in messages.OrderBy(m => m.Time))
                {
                    <div>
                        <strong>@message.Sender.Name:</strong>
                        <span>@message.TextMessage</span>
                        <span>@message.Time.ToString("HH:mm")</span>
                    </div>
                }
            }
            else
            {
                <p>Нет сообщений</p>
            }
        </div>
    </div>

    <div>
        <h4>Введите текст сообщения:</h4>
        <p>
            <input type="text" @bind-value="@messageText" @bind-value:event="oninput" />
        </p>
        <button @onclick="SendMessage_Click">
            Отправить сообщение
        </button>
    </div>
}

@code {
    [Parameter]
    public int chatId { get; set; }

    string messageText = "";
    int? userId = null;
    bool initialized = false;
    List<Message> messages = new List<Message>();
    private System.Timers.Timer? _timer;
    private int lastMessageCount = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var result = await session.GetAsync<int>("userId");
            if (result.Success)
            {
                userId = result.Value;
            }

            if (userId != null)
            {
                await LoadMessages();
                StartAutoRefresh();
            }

            initialized = true;
            StateHasChanged();
        }

        if (userId == null && initialized)
        {
            navigation.NavigateTo($"/login");
            return;
        }
    }

    private void StartAutoRefresh()
    {
        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += async (sender, e) => await OnTimerTick();
        _timer.AutoReset = true;
        _timer.Start();
    }

    private async Task OnTimerTick()
    {
        try
        {
            using ApplicationContext db = dbFactory.CreateDbContext();
            var newMessageCount = await db.Messages
                .CountAsync(m => m.ChatId == chatId);

            if (newMessageCount != lastMessageCount)
            {
                await LoadMessages();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка при обновлении: {ex.Message}");
        }
    }

    private async Task LoadMessages()
    {
        using ApplicationContext db = dbFactory.CreateDbContext();

        var chatUser = await db.ChatUsers
            .AnyAsync(cu => cu.UserId == userId && cu.ChatId == chatId);

        if (!chatUser)
        {
            navigation.NavigateTo("/");
            return;
        }

        messages = await db.Messages
            .Include(m => m.Sender)
            .Where(m => m.ChatId == chatId)
            .OrderBy(m => m.Time)
            .ToListAsync();

        lastMessageCount = messages.Count;
    }

    private async Task SendMessage_Click(MouseEventArgs args)
    {
        if (string.IsNullOrWhiteSpace(messageText))
            return;

        using ApplicationContext db = dbFactory.CreateDbContext();

        var message = new Message()
        {
            ChatId = chatId,
            SenderId = userId.Value,
            TextMessage = messageText,
            Time = DateTime.UtcNow
        };

        db.Messages.Add(message);
        await db.SaveChangesAsync();

        messageText = "";
        await LoadMessages();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _timer?.Stop();
        _timer?.Dispose();
    }
}